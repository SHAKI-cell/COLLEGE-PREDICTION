datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String          @id @default(uuid())
  name          String?
  email         String          @unique
  password      String
  image         String?
  role          String          @default("student")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  savedColleges SavedCollege[]
  reviews       Review[]
}

model College {
  id               String          @id @default(uuid())
  name             String
  slug             String          @unique
  description      String
  logo             String
  banner           String
  locationCity     String
  locationState    String
  rating           Float           @default(0.0)
  feesMin          Float
  feesMax          Float
  placementAverage Float
  placementHighest Float
  type             String
  facilities       String          @default("[]")
  admissionInfo    String
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  courses          Course[]
  reviews          Review[]
  savedBy          SavedCollege[]
}

model Course {
  id          String   @id @default(uuid())
  name        String
  duration    Int
  feesAnnual  Float
  eligibility String
  collegeId   String
  college     College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Review {
  id             String   @id @default(uuid())
  rating         Float
  title          String
  content        String
  studentName    String
  stream         String
  graduationYear Int
  collegeId      String
  college        College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  userId         String?
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model SavedCollege {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  collegeId String
  college   College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, collegeId])
}
